<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.DakaxinxiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.DakaxinxiEntity" id="dakaxinxiMap">
        <result property="yuangonggonghao" column="yuangonggonghao"/>
        <result property="yuangongxingming" column="yuangongxingming"/>
        <result property="xingbie" column="xingbie"/>
        <result property="zhiwei" column="zhiwei"/>
        <result property="bumen" column="bumen"/>
        <result property="dakashijian" column="dakashijian"/>
        <result property="dakaleixing" column="dakaleixing"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.DakaxinxiView" >

		SELECT  dakaxinxi.* FROM dakaxinxi  dakaxinxi 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.DakaxinxiView" >
		SELECT * FROM dakaxinxi  dakaxinxi <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>
